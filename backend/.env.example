PORT=3000

# --- Database (MySQL / MariaDB) ---
DB_USER=root
DB_PASS=                 # your DB root password (e.g. the one you set in XAMPP)
DB_NAME=panglaong_db

# Connection method. If DB_SOCKET is set it takes priority over DB_HOST/DB_PORT
# (see config/db.js). Team standard on macOS is XAMPP via its Unix socket:
DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock

# Alternatives (comment out DB_SOCKET above to use TCP):
#   Homebrew MySQL (macOS):  DB_SOCKET=/tmp/mysql.sock
#   Linux / production (TCP): leave DB_SOCKET unset and use:
DB_HOST=localhost
DB_PORT=3306

JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=24h

NODE_ENV=development
