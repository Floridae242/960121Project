# Production environment template — copy to backend/.env ON THE SERVER and fill in.
# NEVER commit the real .env. Prefer your host's secret/env-var manager over a file.

NODE_ENV=production

# Most hosts inject their own PORT; the app already honors process.env.PORT.
PORT=3000

# --- Cloud MySQL (TCP) ---
# In production use DB_HOST/DB_PORT (a managed MySQL). Do NOT set DB_SOCKET.
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_strong_db_password
DB_NAME=panglaong_db

# --- Auth ---
# Generate a fresh secret (do not reuse the dev one):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_freshly_generated_96_char_random_string
JWT_EXPIRES_IN=24h
